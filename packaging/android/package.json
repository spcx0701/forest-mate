{
  "name": "forestmate-android-apk",
  "private": true,
  "version": "1.2.0",
  "description": "ForestMate Kotlin native Android and Wear OS APK packaging",
  "scripts": {
    "build:apk": "./gradlew --no-daemon :app:assembleDebug :wear:assembleDebug",
    "build:release": "./gradlew --no-daemon :app:assembleRelease :wear:assembleRelease",
    "build:wear": "./gradlew --no-daemon :wear:assembleDebug",
    "fingerprint": "./scripts/print-fingerprint.sh"
  }
}
