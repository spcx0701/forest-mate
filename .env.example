# 숲길동무 백엔드 환경변수 — 복사해 .env로 사용 (커밋 금지)
ENV=dev

# DB: 개발은 SQLite, 운영은 PostgreSQL(+PostGIS)
DATABASE_URL=sqlite:///./forestmate.db
# DATABASE_URL=postgresql+psycopg://forest:비밀번호@localhost:5432/forestmate

# 공공데이터포털 인증키 (활용신청 후 발급). 비우면 동일 스키마 스냅샷으로 폴백.
#   - 기상청 단기예보 / 산불위험예보 / 산악기상관측망 공통 키
DATA_GO_KR_KEY=

# AI 숲이 — Claude API 키. 비우면 규칙 기반 의도 엔진으로 동작.
ANTHROPIC_API_KEY=
LLM_MODEL=claude-opus-4-8
LLM_MAX_TOKENS=1024

# 위치정보 통계 표출 최소 군집(위치정보법). 운영 50, 개발 1.
K_ANONYMITY=1

# 조난 감지 — 이동 정지 임계(분), 평가 최소 포인트 수
DISTRESS_STALL_MINUTES=30
DISTRESS_MIN_POINTS=3

# CORS 허용 오리진(콤마 구분). 운영은 앱/웹 도메인만 명시.
CORS_ORIGINS=*
